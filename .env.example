# Server Configuration
NODE_ENV=development
PORT=3010
LOG_LEVEL=info

# Database
MONGODB_URI=mongodb://localhost:27017/flora-corpnet

# JWT Authentication (must match main Flora app)
JWT_SECRET=your-jwt-secret-here

# CorpNet API Configuration
CORPNET_API_KEY=your-corpnet-api-key-here
CORPNET_API_URL=https://api.corpnet.com/v1

# Mock Mode (set to 'true' for development without API credentials)
MOCK_MODE=true

# Service URLs
SERVICE_URL=http://localhost:3010
FRONTEND_URL=http://localhost:3000
